# StreakForge Backend — Environment Variables

PORT=8000
# For local development with a running MongoDB service: mongodb://localhost:27017/streakforge
# For production or persistent cloud development, use your MongoDB Atlas URI:
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxx.mongodb.net/streakforge?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/streakforge
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRE=30d

# Email verification (optional — users auto-verify in dev mode without these)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@streakforge.app

# Frontend URL for verification links
FRONTEND_URL=http://localhost:5173
