AUTH_SECRET=change-this-to-a-long-random-string
CORS_ORIGINS=http://localhost:5173
SQLITE_PATH=streakforge_api.db

# Oracle Cloud Database. Leave ORACLE_DB_DSN empty to use local SQLite.
ORACLE_DB_USER=
ORACLE_DB_PASSWORD=
ORACLE_DB_DSN=
ORACLE_WALLET_LOCATION=
ORACLE_WALLET_PASSWORD=

# Frontend build-time API target.
VITE_API_BASE=http://localhost:8000
