PORT=8000
MONGO_URI=mongodb://localhost:27017/streakforge # Update to your local MongoDB or Atlas connection DSN
JWT_SECRET=replace-with-a-long-random-secret-key
JWT_EXPIRE=30d
FRONTEND_URL=https://your-domain.com # Replace with your custom domain or Oracle Instance Public IP

# Nodemailer SMTP settings for email verification
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@streakforge.app
